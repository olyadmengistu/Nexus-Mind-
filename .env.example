# Firebase Configuration (for client-side auth and Firestore)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Backend Configuration
PORT=3001
CLIENT_URL=http://localhost:3000

# Frontend API (leave empty in dev — Vite proxies /api to backend)
VITE_API_BASE_URL=
VITE_SOCKET_URL=

# Email Configuration (for feedback notifications)
GMAIL_EMAIL=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-app-password
EMAIL_ADDRESS=noreply@nexusmind.com
ADMIN_EMAILS=your-admin-email@gmail.com
